body {
      background-color: #f0f0f0;
      font-family: Arial;
      text-align: center;
      padding-top: 50px;
    }

    h1 {
      color: #333;
    }

    input {
      padding: 10px;
      width: 200px;
      border-radius: 10px;
      border: 1px solid #ccc;
    }

    button {
      padding: 10px;
      border-radius: 10px;
      border: none;
      background-color: green;
      color: white;
      margin-left: 10px;
    }

    p {
      margin-top: 20px;
      color: gray;
    }
 
