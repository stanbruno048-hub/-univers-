<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<title>Bien sûr Univers</title>

<style>
body {
  margin: 0;
  font-family: Arial, sans-serif;
  background: #111;
  color: white;
}

/* HEADER */
.header {
  background: #1f1f1f;
  padding: 15px;
  text-align: center;
  font-size: 20px;
  font-weight: bold;
}

/* ZONE MESSAGES */
#messages {
  height: 400px;
  overflow-y: auto;
  padding: 10px;
}

/* MESSAGE */
.message {
  background: #2a2a2a;
  padding: 10px;
  margin: 5px 0;
  border-radius: 10px;
  width: fit-content;
  max-width: 70%;
}

/* INPUT ZONE */
.input-zone {
  display: flex;
  padding: 10px;
  background: #1f1f1f;
}

input {
  flex: 1;
  padding: 10px;
  border-radius: 20px;
  border: none;
  outline: none;
}

button {
  margin-left: 10px;
  padding: 10px 15px;
  border: none;
  border-radius: 50%;
  background: #00ff88;
  cursor: pointer;
}
</style>

</head>

<body>

<div class="header">Bien sûr Univers</div>

<div id="messages"></div>

<div class="input-zone">
  <input type="text" id="input" placeholder="Écris un message...">
  <button onclick="envoyer()">➤</button>
</div>

<script>
function envoyer() {
  let input = document.getElementById("input");
  let messages = document.getElementById("messages");

  if (input.value.trim() === "") return;

  let msg = document.createElement("div");
  msg.className = "message";
  msg.textContent = input.value;

  messages.appendChild(msg);

  input.value = "";
  messages.scrollTop = messages.scrollHeight;
}
</script>

</body>
</html>
